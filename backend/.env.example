# Supabase pooled URL (recommended for runtime)
# Example: postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/zusim_inventory"

# Direct database URL (used by Prisma migrations)
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DIRECT_URL="postgresql://postgres:password@localhost:5432/zusim_inventory"

PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins
FRONTEND_URLS="http://localhost:5173"
