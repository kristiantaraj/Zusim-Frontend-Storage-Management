{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --omit=dev && npx prisma generate"
  },
  "deploy": {
    "startCommand": "node src/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "preDeployCommand": "if [ -n \"$DIRECT_URL\" ]; then export DATABASE_URL=\"$DIRECT_URL\"; fi; npx prisma migrate deploy"
  }
}
